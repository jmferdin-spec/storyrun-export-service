# Port the server listens on (Railway sets this automatically)
PORT=3001

# Optional: restrict CORS to your Vercel domain only
# Comma-separated list, or * for open access
ALLOWED_ORIGIN=https://your-app.vercel.app

# Optional: shared secret so only your Vercel app can call this
# Set the same value in Vercel as EXPORT_SERVICE_SECRET
API_SECRET=change-me-to-a-random-string
